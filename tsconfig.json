{
  "compilerOptions": {
    "target": "es2021",
    "module": "commonjs",
    "sourceMap": false,
    "outDir": "dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "src",
    "tests",
    "file.ts"
  ],
  "exclude": [
    "node_modules",
  ]
}
